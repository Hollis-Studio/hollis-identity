{
  "name": "@hollis-studio/identity",
  "version": "0.1.0-alpha.2",
  "description": "Hollis Identity Service — standalone auth service (Express + Prisma + Postgres + ECS Fargate)",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "node --import tsx --test src/__tests__/*.test.ts",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@aws-sdk/client-sesv2": "^3.1049.0",
    "@hollis-studio/contracts": "0.2.0-alpha.12",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.6.0",
    "@sentry/node": "^10.53.1",
    "@types/cors": "^2.8.19",
    "@types/pg": "^8.20.0",
    "bcryptjs": "3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "5.2.1",
    "express-rate-limit": "^8.5.1",
    "jsonwebtoken": "9.0.3",
    "pg": "^8.20.0",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.2",
    "prisma": "^7.6.0",
    "tsx": "^4.21.0",
    "typescript": "5.9.2"
  }
}
