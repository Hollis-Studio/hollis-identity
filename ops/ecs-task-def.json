{
  "_comment": "TODO(W6-ops): Replace this placeholder with the actual ECS task definition for hollis-identity.",
  "family": "hollis-identity",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "containerDefinitions": [
    {
      "name": "hollis-identity",
      "image": "<ACCOUNT_ID>.dkr.ecr.<REGION>.amazonaws.com/hollis-identity:latest",
      "portMappings": [
        {
          "containerPort": 3001,
          "protocol": "tcp"
        }
      ],
      "environment": [],
      "secrets": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/hollis-identity",
          "awslogs-region": "<REGION>",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
