# ============================================================
# Hollis Identity Service — required environment variables
# ============================================================

# PostgreSQL connection string (Prisma DATABASE_URL)
DATABASE_URL=postgresql://user:password@localhost:5432/hollis_identity

# Optional PEM CA bundle for production PostgreSQL TLS verification.
# Use literal \n escapes when storing in a single-line secret.
DATABASE_SSL_CA=

# JWT signing. Production must use RS256 and publish JWKS.
JWT_ALGORITHM=HS256
JWT_SECRET=change_me_to_a_long_random_secret
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_KEY_ID=

# Issuer claim placed in every JWT ("iss" field)
JWT_ISSUER=https://identity.hollis.health

# Comma-separated list of valid JWT audiences accepted by this service
# Matches Audience enum in @hollis-studio/contracts
# Example: hollis-health,hollis-workouts
JWT_AUDIENCES=hollis-health,hollis-workouts

# Pepper string mixed into password hashes before hashing (never stored in DB)
PASSWORD_PEPPER=change_me_to_a_long_random_pepper

# Secret used to encrypt MFA TOTP secrets
ENCRYPTION_KEY=change_me_to_a_long_random_encryption_key

# HTTP port the Express server listens on
PORT=4001

# Log level (pino): trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Browser origins allowed to call Identity directly; comma-separated.
# Leave unset for backend-only local development.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Password reset delivery. Use EMAIL_PROVIDER=ses in AWS.
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@hollis.health
RESET_PASSWORD_URL=http://localhost:3000/reset-password
AWS_REGION=us-east-1
